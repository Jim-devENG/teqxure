// Teqxure Admin Platform — Phase 1 schema
// See /Users/owner/.claude/plans/snazzy-watching-tide.md for the design rationale.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth ----------

enum Role {
  SUPER_ADMIN
  PROGRAM_MANAGER
  INSTRUCTOR
  MENTOR
  REVIEWER
  STUDENT
}

model User {
  id                     String        @id @default(cuid())
  email                  String        @unique
  passwordHash           String
  name                   String?
  role                   Role          @default(STUDENT)
  createdAt              DateTime      @default(now())
  lastLoginAt            DateTime?
  failedLoginAttempts    Int           @default(0)
  lockedUntil            DateTime?
  sessions               Session[]
  activityLogs           ActivityLog[]
  invites                InviteToken[]
  cohortEnrollments      CohortEnrollment[]       @relation("CohortEnrollmentStudent")
  cohortStaffRoles       CohortStaffAssignment[]  @relation("CohortStaffUser")
  sprintSubmissions      SprintSubmission[]       @relation("SprintSubmissionStudent")
  reviewedSubmissions    SprintSubmission[]       @relation("SprintSubmissionReviewer")
  studentProduct         StudentProduct?          @relation("StudentProductOwner")
  communityMessages      CommunityMessage[]       @relation("CommunityMessageAuthor")
  threadParticipations   ThreadParticipant[]      @relation("ThreadParticipantUser")
  directMessages         DirectMessage[]          @relation("DirectMessageAuthor")
  certificates           Certificate[]            @relation("CertificateStudent")
  notifications          Notification[]           @relation("NotificationUser")
  notificationPreference NotificationPreference?  @relation("NotificationPreferenceUser")
  announcementsCreated   Announcement[]           @relation("AnnouncementCreatedBy")
}

// ---------- Invites (admin-provisioned account activation) ----------

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ---------- Site-wide settings ----------

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("Teqxure")
  tagline         String?
  logoUrl         String?
  faviconUrl      String?
  contactEmail    String?
  notificationEmail String?
  socialLinks     Json? // [{ label: string, href: string }]
  seoTitle        String?
  seoDescription  String?
  seoImage        String?
  analyticsId     String?
  updatedAt       DateTime @updatedAt
}

// ---------- Homepage sections (generic content engine) ----------

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique
  visible   Boolean  @default(true)
  order     Int      @default(0)
  content   Json
  updatedAt DateTime @updatedAt
}

// ---------- Product showcase ----------

model Product {
  id              String    @id @default(cuid())
  slug            String    @unique
  name            String
  category        String
  oneLiner        String
  description     String
  longDescription String?
  logoUrl         String?
  builtWith       String[]
  screenshots     String[]
  accent          String    @default("blue")
  metricLabel     String
  metricValue     String
  liveUrl         String?
  caseStudyUrl    String?
  status          String    @default("PUBLISHED")
  featured        Boolean   @default(false)
  visible         Boolean   @default(true)
  order           Int       @default(0)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ---------- Framework (7-stage system diagram) ----------

model FrameworkStage {
  id          String  @id @default(cuid())
  index       String
  name        String
  description String
  order       Int     @default(0)
  visible     Boolean @default(true)
}

// ---------- Curriculum ----------

model CurriculumWeek {
  id        String              @id @default(cuid())
  week      Int
  phase     String
  title     String
  order     Int                 @default(0)
  visible   Boolean             @default(true)
  deletedAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  outcomes  CurriculumOutcome[]
}

model CurriculumOutcome {
  id     String         @id @default(cuid())
  weekId String
  week   CurriculumWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  text   String
  order  Int            @default(0)
}

// ---------- FAQ ----------

model FaqItem {
  id        String    @id @default(cuid())
  question  String
  answer    String
  order     Int       @default(0)
  visible   Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ---------- Testimonials ----------

model Testimonial {
  id             String    @id @default(cuid())
  quote          String
  authorName     String
  authorRole     String?
  authorCompany  String?
  avatarUrl      String?
  rating         Int?
  pinned         Boolean   @default(false)
  approved       Boolean   @default(true)
  visible        Boolean   @default(true)
  order          Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ---------- About page: dedicated list collections ----------
// (Singleton About sections — Hero, Story, Mission, Vision, Stats, Founder,
// FAQ intro, SEO — live in HomepageSection under ABOUT_-prefixed keys and
// reuse the generic sectionRegistry engine instead of new models.)

model CoreValue {
  id          String    @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int       @default(0)
  visible     Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Differentiator {
  id          String    @id @default(cuid())
  heading     String
  description String
  icon        String
  order       Int       @default(0)
  visible     Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TeamMember {
  id          String    @id @default(cuid())
  name        String
  role        String
  bio         String?
  photoUrl    String?
  socialLinks Json? // [{ platform: string, href: string }]
  order       Int       @default(0)
  visible     Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ---------- Waitlist form builder (scoped to the live waitlist form) ----------

model WaitlistField {
  id          String    @id @default(cuid())
  label       String
  fieldType   String // TEXT | EMAIL | TEXTAREA | PHONE | SELECT | CHECKBOX | FILE | URL
  placeholder String?
  required    Boolean   @default(false)
  options     Json? // string[] for SELECT / CHECKBOX
  order       Int       @default(0)
  visible     Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WaitlistSubmission {
  id        String   @id @default(cuid())
  data      Json // { [fieldId]: value }
  status    String   @default("NEW") // NEW | REVIEWED
  createdAt DateTime @default(now())
}

// ---------- Email templates (every outbound email is admin-editable) ----------

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  body      String
  updatedAt DateTime @updatedAt
}

// ---------- Events (each event has its own registration form or an external link) ----------

model Event {
  id               String               @id @default(cuid())
  slug             String               @unique
  title            String
  description      String
  startsAt         DateTime
  endsAt           DateTime?
  location         String?
  isVirtual        Boolean              @default(false)
  coverImageUrl    String?
  status           String               @default("DRAFT") // DRAFT | PUBLISHED
  registrationMode String               @default("INTERNAL") // INTERNAL | EXTERNAL
  externalUrl      String?
  order            Int                  @default(0)
  visible          Boolean              @default(true)
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  fields           EventFormField[]
  registrations    EventRegistration[]
}

model EventFormField {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label       String
  fieldType   String // TEXT | EMAIL | TEXTAREA | PHONE | SELECT | CHECKBOX | FILE | URL
  placeholder String?
  required    Boolean   @default(false)
  options     Json?
  order       Int       @default(0)
  visible     Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  data      Json
  status    String   @default("NEW") // NEW | REVIEWED
  createdAt DateTime @default(now())
}

// ---------- Media library (Phase 1: tracked uploads, not the full library UI) ----------

model Media {
  id        String   @id @default(cuid())
  url       String
  key       String   @unique
  fileName  String
  mimeType  String
  size      Int
  altText   String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

// ---------- Activity log (powers the dashboard) ----------

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // created | updated | deleted | reordered | published | unpublished
  entityType String // Product | CurriculumWeek | FaqItem | Testimonial | HomepageSection | ...
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

// ============================================================
// PLATFORM: Engineering Workspace (/platform)
// ============================================================

// ---------- Bootcamp curriculum (Bootcamp -> Week -> Sprint/LiveSession) ----------

model Bootcamp {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String?
  status      String         @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  weeks       PlatformWeek[]
  cohorts     Cohort[]
  resources   Resource[]
}

model PlatformWeek {
  id           String        @id @default(cuid())
  bootcampId   String
  bootcamp     Bootcamp      @relation(fields: [bootcampId], references: [id], onDelete: Cascade)
  weekNumber   Int
  title        String
  objectives   String
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sprints      Sprint[]
  liveSessions LiveSession[]
  resources    Resource[]

  @@unique([bootcampId, weekNumber])
}

// ---------- Cohorts (a timed run of a Bootcamp) ----------

model Cohort {
  id            String                  @id @default(cuid())
  bootcampId    String
  bootcamp      Bootcamp                @relation(fields: [bootcampId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime
  endDate       DateTime?
  status        String                  @default("UPCOMING") // UPCOMING | ACTIVE | COMPLETED
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  enrollments   CohortEnrollment[]
  staff         CohortStaffAssignment[]
  sprints       Sprint[]
  liveSessions  LiveSession[]
  channels      CommunityChannel[]
  announcements Announcement[]
  certificates  Certificate[]
}

model CohortEnrollment {
  id            String   @id @default(cuid())
  cohortId      String
  cohort        Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  studentId     String
  student       User     @relation("CohortEnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  status        String   @default("ACTIVE") // ACTIVE | COMPLETED | WITHDRAWN
  paymentStatus String   @default("PENDING") // PENDING | VERIFIED
  enrolledAt    DateTime @default(now())

  @@unique([cohortId, studentId])
}

model CohortStaffAssignment {
  id       String @id @default(cuid())
  cohortId String
  cohort   Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("CohortStaffUser", fields: [userId], references: [id], onDelete: Cascade)
  role     String // INSTRUCTOR | MENTOR | REVIEWER

  @@unique([cohortId, userId, role])
}

// ---------- Sprints (the Sprint Room) ----------

model Sprint {
  id                   String             @id @default(cuid())
  weekId               String
  week                 PlatformWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  cohortId             String
  cohort               Cohort             @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  goal                 String
  description          String
  deliverables         String
  referenceMaterials   String?
  architectureNotes    String?
  dueAt                DateTime?
  deadlineReminderSent Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  submissions          SprintSubmission[]

  @@unique([weekId, cohortId])
}

model SprintSubmission {
  id            String    @id @default(cuid())
  sprintId      String
  sprint        Sprint    @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  studentId     String
  student       User      @relation("SprintSubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  status        String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | SUBMITTED | UNDER_REVIEW | NEEDS_REVISION | APPROVED | COMPLETED
  content       String?
  submissionUrl String?
  submittedAt   DateTime?
  feedback      String?
  reviewedById  String?
  reviewedBy    User?     @relation("SprintSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  updatedAt     DateTime  @updatedAt

  @@unique([sprintId, studentId])
}

// ---------- Live sessions ----------

model LiveSession {
  id               String       @id @default(cuid())
  weekId           String
  week             PlatformWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  cohortId         String
  cohort           Cohort       @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  startsAt         DateTime
  provider         String // GOOGLE_MEET | ZOOM | TEAMS | YOUTUBE_UNLISTED
  meetingUrl       String
  recordingUrl     String?
  reminder24hSent  Boolean      @default(false)
  reminder1hSent   Boolean      @default(false)
  reminder10mSent  Boolean      @default(false)
  startedNotifSent Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// ---------- My Product (student workspace) ----------

model StudentProduct {
  id               String   @id @default(cuid())
  studentId        String   @unique
  student          User     @relation("StudentProductOwner", fields: [studentId], references: [id], onDelete: Cascade)
  name             String?
  problemStatement String?
  repositoryUrl    String?
  designFilesUrl   String?
  backendUrl       String?
  frontendUrl      String?
  deploymentUrl    String?
  productionUrl    String?
  currentMilestone String?
  mentorNotes      String?
  completionStatus String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED
  updatedAt        DateTime @updatedAt
}

// ---------- Resources (scoped to a Bootcamp or a specific Week) ----------

model Resource {
  id         String        @id @default(cuid())
  bootcampId String?
  bootcamp   Bootcamp?     @relation(fields: [bootcampId], references: [id], onDelete: Cascade)
  weekId     String?
  week       PlatformWeek? @relation(fields: [weekId], references: [id], onDelete: Cascade)
  title      String
  type       String // NOTES | SLIDES | PDF | REPO | PROMPT_PACK | ARCHITECTURE_DIAGRAM | DB_SCHEMA | API_DOC
  url        String
  order      Int           @default(0)
  visible    Boolean       @default(true)
  createdAt  DateTime      @default(now())
}

// ---------- Community (per-cohort channels) ----------

model CommunityChannel {
  id        String             @id @default(cuid())
  cohortId  String
  cohort    Cohort             @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  key       String // general | questions | architecture | showcase | help | announcements
  name      String
  order     Int                @default(0)
  createdAt DateTime           @default(now())
  messages  CommunityMessage[]

  @@unique([cohortId, key])
}

model CommunityMessage {
  id          String           @id @default(cuid())
  channelId   String
  channel     CommunityChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId    String
  author      User             @relation("CommunityMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String
  attachments Json?
  createdAt   DateTime         @default(now())
}

// ---------- Direct messages ----------

model MessageThread {
  id            String              @id @default(cuid())
  createdAt     DateTime            @default(now())
  lastMessageAt DateTime            @default(now())
  participants  ThreadParticipant[]
  messages      DirectMessage[]
}

model ThreadParticipant {
  id         String        @id @default(cuid())
  threadId   String
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId     String
  user       User          @relation("ThreadParticipantUser", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?

  @@unique([threadId, userId])
}

model DirectMessage {
  id          String        @id @default(cuid())
  threadId    String
  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation("DirectMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String
  attachments Json?
  createdAt   DateTime      @default(now())
}

// ---------- Certificates ----------

model Certificate {
  id               String   @id @default(cuid())
  studentId        String
  student          User     @relation("CertificateStudent", fields: [studentId], references: [id], onDelete: Cascade)
  cohortId         String
  cohort           Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  verificationCode String   @unique
  productName      String?
  pdfUrl           String?
  issuedAt         DateTime @default(now())

  @@unique([studentId, cohortId])
}

// ---------- Notifications ----------

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  body        String
  actionLabel String?
  actionUrl   String?
  read        Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

model NotificationPreference {
  id                     String  @id @default(cuid())
  userId                 String  @unique
  user                   User    @relation("NotificationPreferenceUser", fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled           Boolean @default(true)
  inAppEnabled           Boolean @default(true)
  reminderFrequency      String  @default("ALL") // ALL | IMPORTANT_ONLY | NONE
  communityNotifications Boolean @default(true)
}

// ---------- Announcements ----------

model Announcement {
  id          String   @id @default(cuid())
  cohortId    String?
  cohort      Cohort?  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  title       String
  body        String
  createdById String?
  createdBy   User?    @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}
